# ── Neon PostgreSQL ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?ssl=require

# ── Neon Auth ───────────────────────────────────────────────
NEON_JWT_SECRET=your_neon_jwt_secret_here

# ── Groq ────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Gemini ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your_secret_key_here_change_in_production
CORS_ORIGINS=["http://localhost:3000","https://agentforge.app"]
