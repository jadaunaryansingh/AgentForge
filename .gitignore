# ================================================================
#  AgentForge — .gitignore
#  NEVER commit secrets, API keys, or build artifacts
# ================================================================

# ── Environment & Secrets (NEVER COMMIT) ────────────────────────
.env
.env.*
*.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# Specific app env files
apps/api/.env
apps/api/.env.*
apps/web/.env
apps/web/.env.*

# Any file with "secret" or "key" in the name
*secret*
*secrets*
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer

# ── Python / Backend ────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Python lib dirs (scoped — do NOT match frontend src/lib)
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
.virtualenv/

# Testing & Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
nosetests.xml
test-results/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Database ────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
apps/api/agentforge.db
apps/api/*.db

# ── Node.js / Frontend ──────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Build output
dist/
dist-ssr/
build/
**/dist/
apps/web/dist/
*.local

# TypeScript
*.tsbuildinfo

# Vite
.vite/

# ESLint / Prettier cache
.eslintcache
.stylelintcache
.prettiercache

# ── Logs ────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── OS / System Files ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editors ───────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.swn
*~

# JetBrains
*.iml
*.iws
.idea/

# ── Deployment / Cloud ──────────────────────────────────────────
# Keep render.yaml but ignore local deployment notes with sensitive info
DEPLOYMENT_GUIDE.md
DEPLOYMENT_SUMMARY.md
QUICK_DEPLOY.md
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# ── Temporary / Misc ────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
.cache/
.parcel-cache/
tmp/
temp/